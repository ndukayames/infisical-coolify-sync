# ── Infisical ──────────────────────────────────────────
INFISICAL_URL=https://secrets.twingle.ng
INFISICAL_CLIENT_ID=your-machine-identity-client-id
INFISICAL_CLIENT_SECRET=your-machine-identity-client-secret

# ── Coolify ────────────────────────────────────────────
COOLIFY_URL=https://coolify.twingle.ng
COOLIFY_API_TOKEN=your-coolify-api-token

# ── Webhook (optional — set to match secret in Infisical webhook config) ──
WEBHOOK_SECRET=

# ── Service ────────────────────────────────────────────
PORT=3000

# ── App Mapping (JSON array — maps Infisical folders to Coolify apps) ──
# Each entry maps one Infisical secret folder → one Coolify application/service
#
# Fields:
#   workspaceId         - Infisical Project ID (from Project Settings > General)
#   environment         - Infisical environment slug (e.g. "production", "staging")
#   secretPath          - Folder path in Infisical (e.g. "/twingle-backend")
#   coolifyAppUuid      - Coolify resource UUID (from app URL or API)
#   coolifyResourceType - "application" or "service" (default: "application")
#
APP_MAPPING=[{"workspaceId":"your-infisical-project-id","environment":"production","secretPath":"/twingle-backend","coolifyAppUuid":"your-coolify-app-uuid","coolifyResourceType":"application"}]
